generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Case {
  id           String   @id @default(cuid())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  userRole     String
  sceneId      String
  sceneTitle   String

  basicInfo    String
  answers      String

  riskLevel    String
  riskScore    Int
  riskResult   String

  reportData   String?
  reportNumber String?
  paymentVerified Boolean @default(false)
  accessCode      String?
  accessToken     String?
  email           String?                    // 用户邮箱，用于接收验证码
  paymentRequestedAt DateTime?               // 用户请求支付的时间
  verificationCode    String?                // 邮箱验证码
  verificationSentAt  DateTime?              // 验证码发送时间

  orders Order[]
}

model Order {
  id              String   @id @default(cuid())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  caseId          String
  outTradeNo      String   @unique           // 商户订单号（我们生成，传给微信）
  transactionId   String?                    // 微信支付订单号（支付成功后微信返回）
  totalFee        Int                        // 金额，单位：分
  status          String   @default("pending") // pending | paid | failed
  payTime         DateTime?

  case            Case     @relation(fields: [caseId], references: [id])
}
